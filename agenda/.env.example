# Porta em que o servidor Express escuta
PORT=3000

# URL pública do calendário ICS publicado no Outlook/Microsoft 365
CALENDAR_ICS_URL=https://outlook.office365.com/owa/calendar/7390fe9481a141ad939331a8bd576247@saude.ba.gov.br/f56c542fabd0452f9f6c3178fbda6ea23840265162433551595/calendar.ics

